{
  "name": "dbstudio",
  "version": "0.0.1",
  "private": true,
  "description": "Cross-platform database management studio (web + macOS + Windows).",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev:web": "pnpm --filter @dbstudio/web dev",
    "dev:desktop": "pnpm --filter @dbstudio/desktop tauri dev",
    "build:web": "pnpm --filter @dbstudio/web build",
    "desktop:tools": "node scripts/fetch-desktop-tools.mjs",
    "build:desktop": "pnpm run desktop:tools && pnpm --filter @dbstudio/desktop tauri build",
    "server:dev": "cargo run -p dbstudio-server",
    "server:build": "cargo build -p dbstudio-server --release",
    "rust:check": "cargo check --workspace",
    "rust:test": "cargo test --workspace",
    "rust:fmt": "cargo fmt --all",
    "rust:clippy": "cargo clippy --workspace --all-targets -- -D warnings",
    "lint": "pnpm -r --parallel lint",
    "typecheck": "pnpm -r --parallel typecheck",
    "format": "prettier --write .",
    "test:e2e:up": "docker compose -f infra/test/docker-compose.yml up -d",
    "test:e2e:down": "docker compose -f infra/test/docker-compose.yml down -v",
    "test:e2e": "tsx scripts/test-e2e/index.ts",
    "test:e2e:one": "tsx scripts/test-e2e/index.ts --target",
    "demo:up": "docker compose -f infra/compare-demo/docker-compose.yml up -d",
    "demo:down": "docker compose -f infra/compare-demo/docker-compose.yml down -v",
    "demo:status": "docker compose -f infra/compare-demo/docker-compose.yml ps"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "pg": "^8.13.1",
    "mysql2": "^3.11.5",
    "@types/pg": "^8.11.10"
  }
}
