# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
out/
.next/
target/
bin/

# TS / Next incremental cache — committed by accident in earlier
# commits but it's a local cache, not source. Ignored here so future
# diffs don't churn from it.
*.tsbuildinfo

# Tauri
src-tauri/target/
src-tauri/gen/

# Installer-bundled CLI tools (pg_dump, mysqldump, ...). Fetched at
# build time by scripts/fetch-desktop-tools.mjs, never committed —
# they're large, platform-specific, and vendor-licensed. The tracked
# README keeps the directory present for the resources glob.
apps/desktop/src-tauri/tools/*
!apps/desktop/src-tauri/tools/README.md

# Rust
target/
Cargo.lock.bak
**/*.rs.bk

# Environment
.env
.env.*
!.env.example

# IDE
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Local state
*.sqlite
*.sqlite3
*.db
*.db-journal
.dbstudio/

# Secrets
*.pem
*.key
!example.key
infra/*